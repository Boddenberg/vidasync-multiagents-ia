OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_AUDIO_MODEL=gpt-4o-mini-transcribe
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CHROMA_PERSIST_DIR=.chroma
VIDASYNC_DOCS_DIR=knowledge
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_TOP_K=4
RAG_MIN_SCORE=0.12
RAG_CONTEXT_MAX_CHARS=4000
RAG_EMBEDDING_PROVIDER=auto
RAG_EMBEDDING_MODEL=text-embedding-3-small
CHAT_MEMORY_ENABLED=true
CHAT_MEMORY_MAX_TURNS_SHORT_TERM=8
CHAT_MEMORY_SUMMARY_MAX_CHARS=1800
CHAT_MEMORY_CONTEXT_MAX_CHARS=2200
CHAT_MEMORY_MAX_TURN_CHARS=320
PDF_MAX_UPLOAD_BYTES=20971520
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_JSON_PRETTY=false
LOG_HTTP_HEADERS=false
LOG_HTTP_MAX_BODY_BYTES=32768
LOG_HTTP_MAX_BODY_CHARS=4000
METRICS_ENABLED=true
RESPONSE_EXCLUDE_NONE=false
OPENAI_TIMEOUT_SECONDS=60
PLANO_ALIMENTAR_REFEICOES_SECOND_PASS_ENABLED=false
